#!/usr/bin/env bash
set -euo pipefail

echo "Running pre-commit checks..."

# Gate checks — block commit on failure
echo "  [gate] Architecture gate (required checks)..."
uv run legion-dev architecture gate || exit 1

# Advisory checks — warn but don't block
echo "  [advisory] Security scan (bandit)..."
uv run legion-dev architecture security || true

echo ""
echo "Pre-commit checks passed."
